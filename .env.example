# godx-platform-observability — tunable parameters
# Copy to .env and adjust per environment. Pinned defaults work out of the box for dev.

# ── Image versions (semver pinning recommended in prod) ─────────────
LOKI_IMAGE=grafana/loki:3.3.0
PROMTAIL_IMAGE=grafana/promtail:3.3.0
PROMETHEUS_IMAGE=prom/prometheus:v2.55.1
TEMPO_IMAGE=grafana/tempo:2.6.1
GRAFANA_IMAGE=grafana/grafana:11.4.0
OTELCOL_IMAGE=otel/opentelemetry-collector-contrib:0.115.1
OTEL_LGTM_IMAGE=grafana/otel-lgtm:0.8.5

# ── Network (shared with consumer projects) ─────────────────────────
# Set OBS_NETWORK_EXTERNAL=true and pre-create the network so consumer
# compose files can attach via `external: true`.
OBS_NETWORK=observability
OBS_NETWORK_EXTERNAL=false

# ── Host port mapping (dev) ─────────────────────────────────────────
GRAFANA_HOST_PORT=3000
PROM_HOST_PORT=9090
OTLP_GRPC_HOST_PORT=4317
OTLP_HTTP_HOST_PORT=4318
# Loki/Tempo HTTP not exposed by default — front via Grafana / reverse proxy.
# Uncomment to debug:
# LOKI_HOST_PORT=3100
# TEMPO_HTTP_HOST_PORT=3200

# ── Grafana auth ────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000/
# Dev convenience — disables login form. NEVER enable in production.
GRAFANA_ANONYMOUS_ENABLED=false

# ── Retention ───────────────────────────────────────────────────────
LOKI_RETENTION=720h        # 30d
PROM_RETENTION=30d
TEMPO_RETENTION=168h       # 7d

# ── Default resource labels applied by OTel Collector ───────────────
DEPLOYMENT_ENV=dev
